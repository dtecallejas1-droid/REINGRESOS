  `;
  setTimeout(()=>{animCount(document.getElementById('kv1'),tot,true);animCount(document.getElementById('kv2'),d.length,false);animCount(document.getElementById('kv5'),d.length?tot/d.length:0,true);},50);

  const difVal=d.filter(r=>r.motivo==='Diferencia de Precios').reduce((s,r)=>s+r.valor,0);
  const pct=tot>0?((difVal/tot)*100).toFixed(1):0;
  document.getElementById('alrt').innerHTML=difVal>500?`<div class="alert"><span style="font-size:18px;">⚠</span><span><strong>Alerta Sistemas:</strong> "Diferencia de Precios" representa el <strong>${pct}%</strong> del valor total (${fmt(difVal)}). Concentrado en SSM001 — Sup. Select. San Francisco Gotera. Se recomienda revisión urgente con el área de Sistemas.</span></div>`:'';
}

function rDays(){
