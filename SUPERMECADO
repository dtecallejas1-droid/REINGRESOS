function animCount(el,target,isFloat=false){
  if(!el)return;
  let cur=0,frames=50;
  const step=target/frames;
  const t=setInterval(()=>{
    cur=Math.min(cur+step,target);
    el.textContent=isFloat?'$'+cur.toLocaleString('es-SV',{minimumFractionDigits:2,maximumFractionDigits:2}):Math.round(cur).toString();
    if(cur>=target)clearInterval(t);
  },16);
}

function rKPIs(){
  const d=fi(),tot=d.reduce((s,r)=>s+r.valor,0),salas=new Set(d.map(r=>r.sala)).size;
  const feb=fiMes('2026-02'),mar=fiMes('2026-03');
  const totF=feb.reduce((s,r)=>s+r.valor,0),totM=mar.reduce((s,r)=>s+r.valor,0);
  const pctDelta=totF>0?((totM-totF)/totF*100):0;
  const ncDelta=mar.length-feb.length;
  const byM={};d.forEach(r=>{byM[r.motivo]=(byM[r.motivo]||0)+r.valor;});
  const topM=Object.entries(byM).sort((a,b)=>b[1]-a[1])[0];
  const byA={};d.forEach(r=>{byA[r.area]=(byA[r.area]||{v:0,c:0});byA[r.area].v+=r.valor;byA[r.area].c++;});
