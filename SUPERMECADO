  cPie=new Chart(document.getElementById('cPie'),{type:'doughnut',data:{labels:s.map(([a])=>a),datasets:[{data:s.map(([,v])=>v),backgroundColor:s.map(([a])=>ACOLOR[a]||'#95a5a6'),borderWidth:3,borderColor:'#fff'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{font:{size:11},boxWidth:11,padding:8,color:'#2a3a4a'}},tooltip:{callbacks:{label:c=>`${c.label}: ${fmt(c.raw)}`}}},animation:{animateScale:true,duration:700}}});
}

function rCnts(){
  const d=fi(),areas=Object.keys(ACOLOR).filter(a=>a!=='Sin clasificar');
  const byA={};areas.forEach(a=>byA[a]=0);d.forEach(r=>{if(byA[r.area]!==undefined)byA[r.area]++;});
  const act=areas.filter(a=>byA[a]>0),max=Math.max(...act.map(a=>byA[a]),1),h=68;
  document.getElementById('cnts').innerHTML=act.map(a=>`
    <div class="cnt-col">
      <div class="cnt-num">${byA[a]}</div>
      <div class="cnt-bar" style="height:${Math.max(3,Math.round(byA[a]/max*h))}px;background:${ACOLOR[a]};width:100%;"></div>
      <div class="cnt-lbl">${a.slice(0,8)}</div>
    </div>`).join('');
}

const chartOpts=(idx=true)=>({indexAxis:idx?'y':'x',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>fmt(c.raw)}}},scales:{x:{ticks:{callback:v=>fmtK(v),font:{size:11},color:'#2a3a4a'},grid:{color:'rgba(0,0,0,0.05)'}},y:{ticks:{font:{size:11},color:'#2a3a4a'},grid:{display:false}}},animation:{duration:700}});

function rArea(){
  const d=fi(),areas=Object.keys(ACOLOR).filter(a=>a!=='Sin clasificar');
  const byA={};areas.forEach(a=>byA[a]=0);d.forEach(r=>{if(byA[r.area]!==undefined)byA[r.area]+=r.valor;});
  if(cArea)cArea.destroy();
  const opts=chartOpts(false);
  opts.scales.x.ticks.callback=v=>fmtK(v);opts.scales.y.ticks.color='#1a3550';
  cArea=new Chart(document.getElementById('cArea'),{type:'bar',data:{labels:areas,datasets:[{data:areas.map(a=>byA[a]),backgroundColor:areas.map(a=>ACOLOR[a]),borderRadius:5,borderSkipped:false}]},options:opts});
}

function rMot(){
  const d=fi(),byM={};d.forEach(r=>{byM[r.motivo]=(byM[r.motivo]||0)+r.valor;});
  const s=Object.entries(byM).sort((a,b)=>b[1]-a[1]).slice(0,9);
  if(cMot)cMot.destroy();
  cMot=new Chart(document.getElementById('cMot'),{type:'bar',data:{labels:s.map(([m])=>m.length>26?m.slice(0,26)+'…':m),datasets:[{data:s.map(([,v])=>v),backgroundColor:s.map(([m])=>tc(m)),borderRadius:4,borderSkipped:false}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>fmt(c.raw),title:t=>s[t[0].dataIndex][0]}}},scales:{x:{ticks:{callback:v=>fmtK(v),font:{size:11},color:'#2a3a4a'},grid:{color:'rgba(0,0,0,0.05)'}},y:{ticks:{font:{size:11},color:'#1a3550'},grid:{display:false}}},animation:{duration:700}}});
}

function rRuta(){
  const d=fi(),byR={};d.forEach(r=>{byR[r.ruta]=(byR[r.ruta]||{v:0,c:0});byR[r.ruta].v+=r.valor;byR[r.ruta].c++;});
  const s=Object.entries(byR).sort((a,b)=>b[1].v-a[1].v);
  if(cRuta)cRuta.destroy();
  cRuta=new Chart(document.getElementById('cRuta'),{type:'bar',data:{labels:s.map(([r])=>r),datasets:[{label:'Valor NC ($)',data:s.map(([,v])=>v.v),backgroundColor:'#1a3550',borderRadius:4,borderSkipped:false,yAxisID:'y'},{label:'Cantidad NC',data:s.map(([,v])=>v.c),backgroundColor:'rgba(192,57,43,0.65)',borderRadius:4,borderSkipped:false,yAxisID:'y1'}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11},boxWidth:11,color:'#1a3550'}}},scales:{y:{ticks:{font:{size:12},color:'#1a3550'},grid:{display:false}},y1:{display:false},x:{ticks:{callback:v=>fmtK(v),font:{size:11},color:'#2a3a4a'},grid:{color:'rgba(0,0,0,0.05)'}},x1:{display:false}},animation:{duration:700}}});
}

function rCmp(){
  const feb=fiMes('2026-02'),mar=fiMes('2026-03');
  const C=['#2980b9','#c0392b'],meses=['Febrero (62 NC)','Marzo (90 NC)'];

  if(cCmpV)cCmpV.destroy();
  cCmpV=new Chart(document.getElementById('cCmpV'),{type:'bar',data:{labels:meses,datasets:[{data:[feb.reduce((s,r)=>s+r.valor,0),mar.reduce((s,r)=>s+r.valor,0)],backgroundColor:C,borderRadius:7,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>fmt(c.raw)}}},scales:{x:{ticks:{font:{size:12},color:'#1a3550'},grid:{display:false}},y:{ticks:{callback:v=>fmtK(v),font:{size:11},color:'#2a3a4a'},grid:{color:'rgba(0,0,0,0.05)'}}},animation:{duration:800}}});

  if(cCmpC)cCmpC.destroy();
  cCmpC=new Chart(document.getElementById('cCmpC'),{type:'bar',data:{labels:meses,datasets:[{data:[feb.length,mar.length],backgroundColor:C,borderRadius:7,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`${c.raw} NC`}}},scales:{x:{ticks:{font:{size:12},color:'#1a3550'},grid:{display:false}},y:{ticks:{font:{size:11},color:'#2a3a4a'},grid:{color:'rgba(0,0,0,0.05)'}}},animation:{duration:800}}});

  const mots=[...new Set([...feb,...mar].map(r=>r.motivo))].sort();
  if(cCmpM)cCmpM.destroy();
  cCmpM=new Chart(document.getElementById('cCmpM'),{type:'bar',data:{labels:mots.map(m=>m.length>24?m.slice(0,24)+'…':m),datasets:[{label:'Febrero',data:mots.map(m=>feb.filter(r=>r.motivo===m).reduce((s,r)=>s+r.valor,0)),backgroundColor:'#2980b9',borderRadius:3,borderSkipped:false},{label:'Marzo',data:mots.map(m=>mar.filter(r=>r.motivo===m).reduce((s,r)=>s+r.valor,0)),backgroundColor:'#c0392b',borderRadius:3,borderSkipped:false}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11},boxWidth:11,color:'#1a3550'}},tooltip:{callbacks:{title:t=>mots[t[0].dataIndex],label:c=>`${c.dataset.label}: ${fmt(c.raw)}`}}},scales:{x:{ticks:{callback:v=>fmtK(v),font:{size:11},color:'#2a3a4a'},grid:{color:'rgba(0,0,0,0.05)'}},y:{ticks:{font:{size:11},color:'#1a3550'},grid:{display:false}}},animation:{duration:800}}});

  const areas=Object.keys(ACOLOR).filter(a=>a!=='Sin clasificar');
  if(cCmpA)cCmpA.destroy();
  cCmpA=new Chart(document.getElementById('cCmpA'),{type:'bar',data:{labels:areas,datasets:[{label:'Febrero',data:areas.map(a=>feb.filter(r=>r.area===a).length),backgroundColor:'#2980b9',borderRadius:3,borderSkipped:false},{label:'Marzo',data:areas.map(a=>mar.filter(r=>r.area===a).length),backgroundColor:'#c0392b',borderRadius:3,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11},boxWidth:11,color:'#1a3550'}}},scales:{x:{ticks:{font:{size:11},color:'#1a3550'},grid:{display:false}},y:{ticks:{font:{size:11},color:'#2a3a4a'},grid:{color:'rgba(0,0,0,0.05)'}}},animation:{duration:800}}});
}

function rSala(){
  const d=fi(),byS={};
  d.forEach(r=>{if(!byS[r.sala])byS[r.sala]={v:0,c:0,ruta:r.ruta,area:r.area};byS[r.sala].v+=r.valor;byS[r.sala].c++;});
  const s=Object.entries(byS).sort((a,b)=>b[1].v-a[1].v);
  const tot=s.reduce((sum,[,v])=>sum+v.v,0);
  document.getElementById('sala-tb').innerHTML=s.map(([sala,{v,c,ruta,area}])=>{
    const pct=tot>0?((v/tot)*100).toFixed(1):0;
    const col=parseFloat(pct)>15?'#c0392b':parseFloat(pct)>5?'#e67e22':'#27ae60';
    return`<tr>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${sala}">${sala}</td>
      <td><span class="tag" style="background:#e8eef4;color:#1a3550;font-size:11px;">${ruta}</span></td>
      <td><span class="tag" style="background:${ACOLOR[area]||'#888'}22;color:${ACOLOR[area]||'#555'};font-size:11px;">${area}</span></td>
      <td class="r" style="color:#c0392b;font-size:12px;">${fmt(v)}</td>
      <td class="r" style="color:${col};font-size:12px;font-weight:700;">${pct}%</td>
      <td class="r" style="font-size:12px;">${c}</td>
      <td><div style="width:${Math.min(parseFloat(pct)*5,100)}px;height:7px;background:${col};border-radius:4px;min-width:2px;"></div></td>
    </tr>`;
  }).join('');
}

function rDet(){
  const q=(document.getElementById('srch')?.value||'').toLowerCase();
  const ord=document.getElementById('sort-sel')?.value||'fecha-desc';
  let d=fi().filter(r=>!q||r.sala.toLowerCase().includes(q)||r.motivo.toLowerCase().includes(q)||r.area.toLowerCase().includes(q)||r.municipio.toLowerCase().includes(q)||r.ruta.toLowerCase().includes(q));
  if(ord==='fecha-desc')d.sort((a,b)=>b.fecha.localeCompare(a.fecha));
  else if(ord==='valor-desc')d.sort((a,b)=>b.valor-a.valor);
  else d.sort((a,b)=>a.valor-b.valor);
  document.getElementById('dcnt').textContent=d.length+' registros';
  document.getElementById('det-tb').innerHTML=d.map(r=>`
    <tr>
      <td style="white-space:nowrap;font-size:12px;">${r.fecha}</td>
      <td style="max-width:190px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;" title="${r.sala}">${r.sala}</td>
      <td><span class="tag" style="background:#e8eef4;color:#1a3550;font-size:11px;">${r.ruta}</span></td>
      <td><span class="tag" style="background:${tc(r.motivo)}22;color:${tc(r.motivo)};font-size:11px;">${r.motivo.length>26?r.motivo.slice(0,26)+'…':r.motivo}</span></td>
      <td style="color:${ACOLOR[r.area]||'#555'};font-weight:700;font-size:11px;">${r.area}</td>
      <td style="color:#5a6a7a;font-size:11px;">${r.municipio}</td>
      <td class="r" style="color:${r.valor>500?'#c0392b':r.valor>50?'#e67e22':'#1a3550'};font-size:12px;">${fmt(r.valor)}</td>
    </tr>`).join('');
}

function showTab(t,btn){
  document.querySelectorAll('.vp').forEach(p=>p.classList.remove('show'));
  document.querySelectorAll('.ntab').forEach(b=>b.classList.remove('on'));
  document.getElementById('tab-'+t).classList.add('show');btn.classList.add('on');
  if(t==='cmp')rCmp();if(t==='sala')rSala();if(t==='det')rDet();
}

function ra(){rKPIs();rDays();rPie();rCnts();rArea();rMot();rRuta();rSala();rDet();if(document.getElementById('tab-cmp').classList.contains('show'))rCmp();}

// Cargar logos reales desde los archivos subidos
async function loadLogos(){
  const files=[
    {path:'/mnt/user-data/uploads/LOGO_LACTOLAC_1.jpeg',id:'logo-lactolac'},
    {path:'/mnt/user-data/uploads/LOGO_YES_1.jpeg',id:'logo-yes'}
  ];
  for(const f of files){
    try{
      const r=await fetch(f.path);
      if(r.ok){
        const blob=await r.blob();
        const url=URL.createObjectURL(blob);
        document.getElementById(f.id).src=url;
      }
    }catch(e){
      // intentar storage
      try{
        const key=f.id==='logo-lactolac'?'logo_lactolac':'logo_yes';
        const stored=await window.storage.get(key);
        if(stored?.value)document.getElementById(f.id).src=stored.value;
      }catch(e2){}
    }
  }
}

loadLogos();
ra();
</script>
